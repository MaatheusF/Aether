{
    "name": "aether-frontend",
    "private": true,
    "type": "module",
    "description": "Pipeline de CSS (Tailwind v4 via PostCSS puro) para o front-end Symfony do Aether.",
    "scripts": {
        "css:build": "postcss assets/styles/app.css -o public/build/app.css",
        "css:watch": "postcss assets/styles/app.css -o public/build/app.css --watch",
        "css:build:prod": "cross-env NODE_ENV=production postcss assets/styles/app.css -o public/build/app.css --no-map"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.0.0",
        "cross-env": "^7.0.3",
        "cssnano": "^7.0.0",
        "postcss": "^8.4.47",
        "postcss-cli": "^11.0.0",
        "tailwindcss": "^4.0.0"
    }
}
