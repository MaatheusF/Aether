{% extends 'base.html.twig' %}

{# ==========================================================================
   dashboard.html.twig — Visão Macro do Ecossistema
   layout_mode = 'full' → base.html.twig não renderiza a sidebar esquerda.
========================================================================== #}

{% block title %}Visão Geral{% endblock %}
{% block layout_mode %}full{% endblock %}
{% block module_active %}{% endblock %}

{% block content %}

    <div class="flex flex-col gap-8">

        {# --------------------- Cabeçalho da página --------------------- #}
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-2">
            <div>
                <p class="text-xs font-mono uppercase tracking-widest text-aether-agua/70 mb-1">Core · Status Geral</p>
                <h1 class="text-2xl md:text-3xl font-extrabold text-slate-50">Visão do Ecossistema</h1>
            </div>
            <p class="text-xs font-mono text-slate-500">
                Última sincronia: <span class="text-slate-300">há 4s</span>
            </p>
        </div>

        {# --------------------- Resumo rápido --------------------- #}
        <div class="glass-surface rounded-2xl p-4 flex flex-wrap items-center gap-x-8 gap-y-3">
            <div>
                <p class="text-[10px] font-mono uppercase tracking-widest text-slate-500">Dispositivos</p>
                <p class="text-lg font-mono text-slate-100">{{ resumo.dispositivos_total }}</p>
            </div>
            <div>
                <p class="text-[10px] font-mono uppercase tracking-widest text-slate-500">Online</p>
                <p class="text-lg font-mono text-aether-broto">{{ resumo.dispositivos_online }}</p>
            </div>
            <div>
                <p class="text-[10px] font-mono uppercase tracking-widest text-slate-500">Alertas ativos</p>
                <p class="text-lg font-mono text-aether-ambar">{{ alertas|length }}</p>
            </div>
        </div>

        {# --------------------- Cards de Alerta (prioridade natural) --------------------- #}
        {# Três estados possíveis: estavel / atencao / critico — 'alertas' vem do
           DashboardController (mock hoje, Core depois); cada card referencia o
           dispositivo específico, necessário desde que o Poseidon passou a
           suportar mais de um ESP32 — sem isso, "nível da água baixo" é ambíguo. #}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {% for alerta in alertas %}
                <div class="bio-dimmable relative overflow-hidden rounded-2xl glass-surface p-4 flex items-start gap-3 border-l-2
                    {{ alerta.nivel == 'critico' ? '!border-l-aether-critico' : (alerta.nivel == 'atencao' ? '!border-l-aether-ambar' : '!border-l-aether-broto') }}">
                    <span class="mt-1 w-2 h-2 rounded-full shrink-0
                        {{ alerta.nivel == 'critico' ? 'bg-aether-critico' : (alerta.nivel == 'atencao' ? 'bg-aether-ambar' : 'bg-aether-broto') }}"></span>
                    <div class="min-w-0">
                        <p class="text-[11px] font-mono uppercase tracking-wider
                            {{ alerta.nivel == 'critico' ? 'text-aether-critico/80' : (alerta.nivel == 'atencao' ? 'text-aether-ambar/80' : 'text-aether-broto/80') }}">
                            {{ alerta.nivel == 'critico' ? 'Crítico' : (alerta.nivel == 'atencao' ? 'Atenção' : 'Estável') }} · {{ alerta.dispositivo }}
                        </p>
                        <p class="text-sm text-slate-200 mt-0.5">{{ alerta.mensagem }}</p>
                    </div>
                </div>
            {% endfor %}
        </div>

        {# --------------------- Visual do Core: raiz/corrente conectando módulos --------------------- #}
        <div class="glass-surface rounded-2xl p-5 md:p-6">
            <p class="text-[11px] font-mono uppercase tracking-widest text-slate-500 mb-4">Fluxo do Core</p>
            <svg viewBox="0 0 600 90" class="w-full h-16 md:h-20" preserveAspectRatio="none">
                {# Linha central representando a corrente/raiz do Core #}
                <path d="M0,45 C100,20 150,70 250,45 C350,20 400,70 500,45 C540,32 570,45 600,45"
                      fill="none" stroke="#22332A" stroke-width="2"/>
                <path d="M0,45 C100,20 150,70 250,45 C350,20 400,70 500,45 C540,32 570,45 600,45"
                      fill="none" stroke="#4EEE94" stroke-width="2" stroke-dasharray="6 10" opacity="0.6">
                    <animate attributeName="stroke-dashoffset" from="0" to="-32" dur="1.8s" repeatCount="indefinite"/>
                </path>
                {# Nós de ramificação — um por módulo, aceso se ONLINE #}
                <circle cx="120" cy="34" r="5" fill="#4EEE94"/>
                <circle cx="330" cy="30" r="5" fill="#00F5FF"/>
                <circle cx="480" cy="58" r="5" fill="#22332A" stroke="#3a4a40" stroke-width="1"/>
            </svg>
        </div>

        {# --------------------- Módulos, um bloco por módulo --------------------- #}
        {# Cada módulo é uma seção própria, não um grid único misturando tudo —
           com mais de um módulo tendo vários dispositivos, um grid só vira
           ilegível rápido (sem pista visual de qual card é de qual módulo).
           Ver DesignSystem.md §3.3/§3.6. #}
        <div class="flex flex-col gap-6">

            {# ---- Seção: Poseidon ---- #}
            <div>
                <div class="flex items-center justify-between mb-3">
                    <p class="text-[11px] font-mono uppercase tracking-widest text-aether-agua/70">Poseidon</p>
                    <p class="text-[11px] font-mono text-slate-600">{{ dispositivos_poseidon|length }} dispositivo{{ dispositivos_poseidon|length != 1 ? 's' : '' }}</p>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
                    {% for d in dispositivos_poseidon %}
                        <a href="{{ path('app_modulo_poseidon_dispositivo', { slug: d.slug }) }}"
                           class="group rounded-2xl glass-surface p-5 flex flex-col gap-4 hover:shadow-glow-agua hover:border-aether-agua/30 transition-all duration-300">
                            <div class="flex items-start justify-between">
                                <div>
                                    <p class="text-xs font-mono text-slate-500 mb-1">
                                        {{ d.tipo == 'paludario' ? 'PALUDÁRIO' : 'AQUÁRIO' }}
                                    </p>
                                    <h2 class="text-lg font-bold text-slate-50">{{ d.nome }}</h2>
                                </div>
                                <span class="flex items-center gap-1.5 text-[11px] font-mono px-2 py-1 rounded-full
                                    {{ d.status == 'online' ? 'bg-aether-broto/10 text-aether-broto' : (d.status == 'alert' ? 'bg-aether-critico/10 text-aether-critico' : 'bg-white/5 text-slate-500') }}">
                                    <span class="w-1.5 h-1.5 rounded-full {{ d.status == 'online' ? 'bg-aether-broto' : (d.status == 'alert' ? 'bg-aether-critico' : 'bg-slate-500') }}"></span>
                                    {{ d.status == 'online' ? 'ONLINE' : (d.status == 'alert' ? 'ALERTA' : 'OFFLINE') }}
                                </span>
                            </div>

                            {# Telemetria rápida #}
                            <div class="grid grid-cols-3 gap-2 pt-3 border-t border-aether-border">
                                <div>
                                    <p class="text-[10px] font-mono text-slate-500 uppercase">Água</p>
                                    <p class="text-sm font-mono text-aether-agua">{{ d.telemetria.temp_agua|default('--') }}</p>
                                </div>
                                <div>
                                    <p class="text-[10px] font-mono text-slate-500 uppercase">Umid.</p>
                                    <p class="text-sm font-mono text-aether-broto">{{ d.telemetria.umidade|default('--') }}</p>
                                </div>
                                <div>
                                    <p class="text-[10px] font-mono text-slate-500 uppercase">Luz</p>
                                    <p class="text-sm font-mono text-aether-ambar">{{ d.telemetria.luz|default('--') }}</p>
                                </div>
                            </div>
                        </a>
                    {% else %}
                        <div class="rounded-2xl border border-dashed border-aether-border p-5 flex items-center justify-center text-center text-xs font-mono text-slate-600 sm:col-span-2 xl:col-span-3">
                            Nenhum dispositivo Poseidon cadastrado ainda.
                        </div>
                    {% endfor %}
                </div>
            </div>

            {# ---- Seção: Horus ---- #}
            {# Só existe UM Horus por instalação (não há vários dispositivos
               como no Poseidon — câmeras/portão/sensores são todos partes do
               mesmo módulo) — por isso ocupa a linha inteira em vez de entrar
               num grid de cards, o que sobra espaço pra mais indicadores lado
               a lado em vez de espremidos num card estreito. #}
            <div>
                <div class="flex items-center justify-between mb-3">
                    <p class="text-[11px] font-mono uppercase tracking-widest text-aether-ambar/70">Horus</p>
                </div>
                <a href="{{ path('app_modulo_horus') }}"
                   class="group block rounded-2xl glass-surface p-5 hover:shadow-glow-broto hover:border-aether-broto/30 transition-all duration-300">
                    <div class="flex items-start justify-between mb-4">
                        <div>
                            <p class="text-xs font-mono text-slate-500 mb-1">SEGURANÇA</p>
                            <h2 class="text-lg font-bold text-slate-50">Horus</h2>
                        </div>
                        <span class="flex items-center gap-1.5 text-[11px] font-mono px-2 py-1 rounded-full
                            {{ horus.status == 'online' ? 'bg-aether-broto/10 text-aether-broto' : (horus.status == 'alert' ? 'bg-aether-ambar/10 text-aether-ambar' : 'bg-white/5 text-slate-500') }}">
                            <span class="w-1.5 h-1.5 rounded-full {{ horus.status == 'online' ? 'bg-aether-broto' : (horus.status == 'alert' ? 'bg-aether-ambar' : 'bg-slate-500') }}"></span>
                            {{ horus.status == 'online' ? 'ONLINE' : (horus.status == 'alert' ? 'ALERTA' : 'OFFLINE') }}
                        </span>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 pt-4 border-t border-aether-border">
                        {# Câmeras ativas/disponíveis #}
                        <div class="flex items-center gap-3">
                            <span class="flex items-center justify-center w-9 h-9 rounded-lg bg-white/5 text-slate-400 shrink-0">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="w-4.5 h-4.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5V6a1.5 1.5 0 0 0-1.5-1.5H4.5A1.5 1.5 0 0 0 3 6v9a1.5 1.5 0 0 0 1.5 1.5h9A1.5 1.5 0 0 0 15 15v-4.5Zm0 0 4.72-2.36a.75.75 0 0 1 1.08.67v7.38a.75.75 0 0 1-1.08.67L15 13.5" />
                                </svg>
                            </span>
                            <div>
                                <p class="text-[10px] font-mono uppercase text-slate-500">Câmeras</p>
                                <p class="text-sm font-mono text-slate-100">{{ horus.camerasAtivas }}<span class="text-slate-500 text-sm">/{{ horus.camerasTotal }}</span></p>
                            </div>
                        </div>

                        {# Dispositivos ativos/disponíveis #}
                        <div class="flex items-center gap-3">
                            <span class="flex items-center justify-center w-9 h-9 rounded-lg bg-white/5 text-slate-400 shrink-0">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="w-4.5 h-4.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M15.75 3v1.5M3 8.25h18M5.25 5.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25Z" />
                                </svg>
                            </span>
                            <div>
                                <p class="text-[10px] font-mono uppercase text-slate-500">Dispositivos</p>
                                <p class="text-sm font-mono text-slate-100">{{ horus.dispositivosAtivos }}<span class="text-slate-500 text-sm">/{{ horus.dispositivosTotal }}</span></p>
                            </div>
                        </div>

                        {# Portão: travado/destravado #}
                        <div class="flex items-center gap-3">
                            <span class="flex items-center justify-center w-9 h-9 rounded-lg shrink-0
                                {{ horus.portaoEstado == 'travado' ? 'bg-aether-broto/10 text-aether-broto' : 'bg-aether-ambar/10 text-aether-ambar' }}">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="w-4.5 h-4.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 9.75V6a3.75 3.75 0 1 1 7.5 0M6.75 21h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75A2.25 2.25 0 0 0 6.75 21Z" />
                                </svg>
                            </span>
                            <div>
                                <p class="text-[10px] font-mono uppercase text-slate-500">Portão</p>
                                <p class="text-sm font-mono {{ horus.portaoEstado == 'travado' ? 'text-aether-broto' : 'text-aether-ambar' }}">
                                    {{ horus.portaoEstado == 'travado' ? 'Travado' : 'Destravado' }}
                                </p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>

            {# ---- Novo módulo ---- #}
            <div class="rounded-2xl border border-dashed border-aether-border p-5 flex items-center justify-center gap-2 text-slate-600">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                <p class="text-xs font-mono">Novo módulo</p>
            </div>
        </div>
    </div>

{% endblock %}
