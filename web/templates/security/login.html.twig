{#
    Aether — Tela de Login
    ----------------------
    Estilo: "biotopo digital" — um paludário noturno visto através do vidro.
#}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aether — Acesso</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,600;1,9..144,400&family=Manrope:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="{{ asset('css/login.css') }}">
</head>
<body>

{# ---------- Cena de fundo ---------- #}
<div class="scene" aria-hidden="true">
    <div class="caustics"></div>

    <div class="ferns left">
        <svg viewBox="0 0 300 420" xmlns="http://www.w3.org/2000/svg">
            <g fill="#07130f">
                <path class="frond" d="M40 420 C 30 300, 70 220, 20 140 C 60 180, 90 230, 95 300 C 100 230, 80 160, 110 90 C 115 170, 130 230, 120 320 C 140 250, 145 180, 175 120 C 165 210, 160 280, 150 380 C 150 400 100 420 40 420 Z"/>
                <path class="frond" d="M170 420 C 160 320, 190 260, 160 190 C 190 220, 205 260, 205 320 C 215 260, 210 210, 235 160 C 235 230, 240 280, 230 360 C 250 310, 255 260, 275 220 C 265 280, 260 330, 250 400 C 245 415, 210 420, 170 420 Z" opacity="0.85"/>
            </g>
        </svg>
    </div>

    <div class="ferns right">
        <svg viewBox="0 0 300 420" xmlns="http://www.w3.org/2000/svg">
            <g fill="#07130f">
                <path class="frond" d="M40 420 C 30 300, 70 220, 20 140 C 60 180, 90 230, 95 300 C 100 230, 80 160, 110 90 C 115 170, 130 230, 120 320 C 140 250, 145 180, 175 120 C 165 210, 160 280, 150 380 C 150 400 100 420 40 420 Z"/>
                <path class="frond" d="M170 420 C 160 320, 190 260, 160 190 C 190 220, 205 260, 205 320 C 215 260, 210 210, 235 160 C 235 230, 240 280, 230 360 C 250 310, 255 260, 275 220 C 265 280, 260 330, 250 400 C 245 415, 210 420, 170 420 Z" opacity="0.85"/>
            </g>
        </svg>
    </div>

    <div class="fish fish-1">
        <svg viewBox="0 0 64 30" xmlns="http://www.w3.org/2000/svg" fill="#0e2320">
            <path d="M2 15 C 14 2, 40 2, 50 15 C 40 28, 14 28, 2 15 Z M50 15 L 62 6 L 58 15 L 62 24 Z"/>
        </svg>
    </div>
    <div class="fish fish-2">
        <svg viewBox="0 0 64 30" xmlns="http://www.w3.org/2000/svg" fill="#0e2320">
            <path d="M2 15 C 14 2, 40 2, 50 15 C 40 28, 14 28, 2 15 Z M50 15 L 62 6 L 58 15 L 62 24 Z"/>
        </svg>
    </div>
    <div class="fish fish-3">
        <svg viewBox="0 0 64 30" xmlns="http://www.w3.org/2000/svg" fill="#0e2320">
            <path d="M2 15 C 14 2, 40 2, 50 15 C 40 28, 14 28, 2 15 Z M50 15 L 62 6 L 58 15 L 62 24 Z"/>
        </svg>
    </div>

    <div class="bubbles" id="bubbles"></div>
    <div class="vignette"></div>
</div>

{# ---------- Painel de login ---------- #}
<div class="stage">
    <div class="panel">
        <div class="brand">
            <svg class="brand-mark" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
                <circle cx="32" cy="32" r="30" fill="none" stroke="#d9b45c" stroke-width="1" opacity="0.45"/>
                <circle cx="32" cy="32" r="23" fill="none" stroke="#8fc4a3" stroke-width="1" opacity="0.5"/>
                <path d="M32 14 C 24 22, 24 32, 32 50 C 40 32, 40 22, 32 14 Z" fill="none" stroke="#eef4ef" stroke-width="1.4"/>
                <path d="M32 20 C 32 28, 32 38, 32 46" stroke="#eef4ef" stroke-width="1" opacity="0.6"/>
                <path d="M32 24 C 27 26, 25 29, 24 33" stroke="#8fc4a3" stroke-width="1" fill="none" opacity="0.8"/>
                <path d="M32 30 C 37 32, 39 35, 40 39" stroke="#8fc4a3" stroke-width="1" fill="none" opacity="0.8"/>
            </svg>

            <h1 class="brand-title">A<em>e</em>ther</h1>
            <p class="brand-subtitle">Conectado à Singularidade.</p>
        </div>

        {# Fluxo padrão do Symfony Security — ajuste os nomes conforme seu SecurityController2 #}
        {% if error is defined and error %}
            <div class="flash-error">
                ⚠ {{ error.messageKey|trans(error.messageData, 'security')|default('  Usuário ou senha inválidos.') }}
            </div>
        {% endif %}

        <form method="post" action="{{ path('app_login') }}">
            <div class="field">
                <label for="username">Usuário</label>
                <input type="text" id="username" name="username"
                       value="{{ last_username|default('') }}"
                       placeholder="seu.usuario" autocomplete="username" required autofocus>
            </div>

            <div class="field">
                <label for="password">Senha</label>
                <input type="password" id="password" name="password"
                       placeholder="••••••••" autocomplete="current-password" required>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="submit-btn">Entrar</button>
        </form>

        <p class="footer-note">Aether<span class="dot"></span>Acesso Restrito</p>
    </div>
</div>

<script src="{{ asset('js/login.js') }}"></script>
</body>
</html>
