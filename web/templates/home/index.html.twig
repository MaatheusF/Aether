{#
Aether — Home / Painel
----------------------

Este template espera receber do controller uma variável `modules`
(array de objetos/hashes). Se ela não vier, uso uma lista de exemplo
abaixo — troque pelos módulos reais do Aether quando ligar o backend.

Formato esperado de cada item de `modules`:
  {
    name: 'Aquário',
    slug: 'aquario',
    icon: 'wave',            # wave | sun | leaf | shield | calendar | droplet | folder
    description: 'Texto curto de status ou apoio.',
    status: 'ok' | 'warn' | 'off',
    status_label: 'Online',
    route: 'app_module_aquario'
  }

Ícones e itens de menu são genéricos — ajuste depois conforme os
módulos reais do sistema.
#}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aether — Painel</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,600;1,9..144,400&family=Manrope:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="{{ asset('css/home.css') }}">
</head>
<body>

{# decoração estática de fundo — sem animação #}
<div class="bg-fern left" aria-hidden="true">
    <svg viewBox="0 0 300 420" xmlns="http://www.w3.org/2000/svg">
        <path fill="#0d211c" d="M40 420 C 30 300, 70 220, 20 140 C 60 180, 90 230, 95 300 C 100 230, 80 160, 110 90 C 115 170, 130 230, 120 320 C 140 250, 145 180, 175 120 C 165 210, 160 280, 150 380 C 150 400 100 420 40 420 Z"/>
    </svg>
</div>
<div class="bg-fern right" aria-hidden="true">
    <svg viewBox="0 0 300 420" xmlns="http://www.w3.org/2000/svg">
        <path fill="#0d211c" d="M40 420 C 30 300, 70 220, 20 140 C 60 180, 90 230, 95 300 C 100 230, 80 160, 110 90 C 115 170, 130 230, 120 320 C 140 250, 145 180, 175 120 C 165 210, 160 280, 150 380 C 150 400 100 420 40 420 Z"/>
    </svg>
</div>

{# ---------- Topbar ---------- #}
<header class="topbar">
    <div class="topbar-inner">

        <a class="brand" href="{{ path('app_home') }}">
            <svg class="brand-mark" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
                <circle cx="32" cy="32" r="30" fill="none" stroke="#d9b45c" stroke-width="1" opacity="0.45"/>
                <circle cx="32" cy="32" r="23" fill="none" stroke="#8fc4a3" stroke-width="1" opacity="0.5"/>
                <path d="M32 14 C 24 22, 24 32, 32 50 C 40 32, 40 22, 32 14 Z" fill="none" stroke="#eef4ef" stroke-width="1.4"/>
                <path d="M32 20 C 32 28, 32 38, 32 46" stroke="#eef4ef" stroke-width="1" opacity="0.6"/>
                <path d="M32 24 C 27 26, 25 29, 24 33" stroke="#8fc4a3" stroke-width="1" fill="none" opacity="0.8"/>
                <path d="M32 30 C 37 32, 39 35, 40 39" stroke="#8fc4a3" stroke-width="1" fill="none" opacity="0.8"/>
            </svg>
            <span class="brand-name">A<em>e</em>ther</span>
        </a>

        <nav class="main-nav" aria-label="Navegação principal">
            <a class="nav-item active" href="{{ path('app_home') }}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
                <span>Painel</span>
            </a>


            <a class="nav-item" href="#">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 15c2 2 4 2 6 0s4-2 6 0 4 2 6 0"/><path d="M2 10c2 2 4 2 6 0s4-2 6 0 4 2 6 0"/></svg>
                <span>Aquário</span>
            </a><!-- MODULOS INATIVOS
            <a class="nav-item" href="#">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4.5"/><path d="M12 2.5v3M12 18.5v3M4.2 4.2l2.1 2.1M17.7 17.7l2.1 2.1M2.5 12h3M18.5 12h3M4.2 19.8l2.1-2.1M17.7 6.3l2.1-2.1"/></svg>
                <span>Iluminação</span>
            </a>
            <a class="nav-item" href="#">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3c4 3 6 6.5 6 10a6 6 0 0 1-12 0c0-3.5 2-7 6-10Z"/><path d="M12 9v9"/></svg>
                <span>Paludário</span>
            </a>
            <a class="nav-item" href="#">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.7-7 10-4-2.3-7-5.5-7-10V6l7-3Z"/></svg>
                <span>Segurança</span>
            </a>
            <a class="nav-item" href="#">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4.5" width="18" height="16" rx="2"/><path d="M3 9.5h18M8 3v3M16 3v3"/></svg>
                <span>Agendas</span>
            </a>-->
        </nav>

        <div class="topbar-actions">
            <span class="status-dot">Aether ativo</span>

            <button class="icon-btn" id="settings-toggle" type="button"
                    aria-haspopup="true" aria-expanded="false" aria-label="Configurações do sistema">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="3.2"/>
                    <path d="M4.6 9.2l1.5.4M17.9 14.4l1.5.4M6.1 14.4l-1.5.4M19.4 9.6l-1.5.4M12 4v1.6M12 18.4V20M8.3 5.1l.8 1.4M15.7 5.1l-.8 1.4M8.3 18.9l.8-1.4M15.7 18.9l-.8-1.4"/>
                </svg>
            </button>

            <div class="settings-menu" id="settings-menu" role="menu">
                <a href="#" role="menuitem">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l2.5 2.5"/></svg>
                    Preferências
                </a>
                <a href="#" role="menuitem">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.2"/><path d="M2.5 20c1-3.5 3.6-5.3 6.5-5.3s5.5 1.8 6.5 5.3"/><circle cx="18" cy="8.5" r="2.4"/><path d="M15.8 14.9c2.3.2 4.1 1.8 4.7 4"/></svg>
                    Usuários
                </a>
                <a href="#" role="menuitem">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="14" rx="2"/><path d="M3 9h18"/></svg>
                    Registros do sistema
                </a>
                <div class="divider"></div>
                <a href="#" role="menuitem">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v4.5M12 16h.01"/></svg>
                    Sobre o Aether
                </a>
                <a href="/logout" role="menuitem" class="danger">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 4H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h3"/><path d="M15 16l4-4-4-4"/><path d="M19 12H9"/></svg>
                    Sair
                </a>
            </div>
        </div>

    </div>
</header>

{# ---------- Conteúdo principal ---------- #}
<main class="dashboard">

    <div class="dashboard-header">
        <div>
            <p class="dashboard-eyebrow">Painel</p>
            <h1 class="dashboard-title">Bem-vindo de volta</h1>
            <p class="dashboard-subtitle">Visão geral dos módulos conectados ao Aether</p>
        </div>
        <div class="system-status"><span>Core estável — sem alertas</span></div>
    </div>

    {# Lista de exemplo — substitua pela variável real vinda do controller #}
    {% set modules = modules|default([
        { name: 'Aquário', slug: 'aquario', icon: 'wave', description: 'Temperatura, filtragem e alimentação automática.', status: 'off', status_label: 'Desconhecido' }
    ]) %}

    {# Lista de exemplo #}
    {#    { name: 'Iluminação', slug: 'iluminacao', icon: 'sun', description: 'Ciclos de luz das áreas internas e externas.', status: 'ok', status_label: 'Online' },#}
    {#    { name: 'Paludário', slug: 'paludario', icon: 'leaf', description: 'Umidade, névoa e irrigação do biotopo.', status: 'warn', status_label: 'Atenção' },#}
    {#    { name: 'Segurança', slug: 'seguranca', icon: 'shield', description: 'Câmeras, sensores e controle de acesso.', status: 'off', status_label: 'Desligado' },#}
    {#    { name: 'Agendas', slug: 'agendas', icon: 'calendar', description: 'Rotinas pessoais e automações programadas.', status: 'off', status_label: 'Desligado' },#}
    {#    { name: 'Irrigação', slug: 'irrigacao', icon: 'droplet', description: 'Zonas de rega do jardim e das estufas.', status: 'off', status_label: 'Desligado' },#}
    {#    { name: 'Arquivos', slug: 'arquivos', icon: 'folder', description: 'Backups, logs e documentos do sistema.', status: 'ok', status_label: 'Desligado' },#}

    <section class="modules-grid">
        {% for module in modules %}
            <a class="module-card" href="{{ module.route is defined ? path(module.route) : '#' }}">
                <div class="module-card-top">
                        <span class="module-icon">
                            {% if module.icon == 'wave' %}
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 15c2 2 4 2 6 0s4-2 6 0 4 2 6 0"/><path d="M2 10c2 2 4 2 6 0s4-2 6 0 4 2 6 0"/></svg>
                            {% elseif module.icon == 'sun' %}
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4.5"/><path d="M12 2.5v3M12 18.5v3M4.2 4.2l2.1 2.1M17.7 17.7l2.1 2.1M2.5 12h3M18.5 12h3M4.2 19.8l2.1-2.1M17.7 6.3l2.1-2.1"/></svg>
                            {% elseif module.icon == 'leaf' %}
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3c4 3 6 6.5 6 10a6 6 0 0 1-12 0c0-3.5 2-7 6-10Z"/><path d="M12 9v9"/></svg>
                            {% elseif module.icon == 'shield' %}
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.7-7 10-4-2.3-7-5.5-7-10V6l7-3Z"/></svg>
                            {% elseif module.icon == 'calendar' %}
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4.5" width="18" height="16" rx="2"/><path d="M3 9.5h18M8 3v3M16 3v3"/></svg>
                            {% elseif module.icon == 'droplet' %}
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.5c3.5 4.5 7 8.6 7 12.3a7 7 0 1 1-14 0c0-3.7 3.5-7.8 7-12.3Z"/></svg>
                            {% elseif module.icon == 'folder' %}
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6.5a1.5 1.5 0 0 1 1.5-1.5h4l2 2.5h9A1.5 1.5 0 0 1 21 9v8.5A1.5 1.5 0 0 1 19.5 19h-15A1.5 1.5 0 0 1 3 17.5v-11Z"/></svg>
                            {% else %}
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8"/></svg>
                            {% endif %}
                        </span>

                    <span class="module-indicator {{ module.status }}">
                            <span class="dot"></span>{{ module.status_label }}
                        </span>
                </div>

                <div>
                    <h2 class="module-name">{{ module.name }}</h2>
                    <p class="module-desc">{{ module.description }}</p>
                </div>

                <span class="module-link">
                        Abrir módulo
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                    </span>
            </a>
        {% endfor %}
    </section>

</main>

<script src="{{ asset('js/home.js') }}"></script>
</body>
</html>
