{# ==========================================================================
   base.html.twig — Esqueleto mestre do Aether
   Estética: Eco-Tech / Biopunk (paludário digital)
   Contém: Topbar "Dossel", Sidebar Esquerda "Raízes" (dinâmica), Bottom Nav
   mobile e o mecanismo de Bio-Dimming.

   Blocos que os filhos podem sobrescrever:
     - title            → título da aba
     - layout_mode       → 'full' (sem sidebar, ex: dashboard) ou 'sidebar'
                            (com sidebar de módulo). Controla o grid.
     - module_active     → slug do módulo ativo, usado para destacar links
                            no topbar/bottom nav (ex: 'poseidon', 'horus')
     - sidebar           → conteúdo da sidebar esquerda (links do módulo)
     - content           → conteúdo principal da página
     - stylesheets/javascripts → extensões por página
========================================================================== #}
<!DOCTYPE html>
<html lang="pt-BR" data-bio-dim="false">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>{% block title %}Aether{% endblock %} · Aether</title>

    {# Fontes: Plus Jakarta Sans (UI) + JetBrains Mono (dados/logs) #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

    {# Tailwind via CDN — trocar por build (Vite/PostCSS) quando integrar ao Symfony AssetMapper/Webpack Encore #}
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'aether-bg': '#0E1310',
                        'aether-bg-alt': '#0D1117',
                        'aether-surface': '#141C18',
                        'aether-border': '#22332A',
                        'aether-broto': '#4EEE94',
                        'aether-agua': '#00F5FF',
                        'aether-ambar': '#FFB900',
                        'aether-critico': '#FF5C5C',
                    },
                    fontFamily: {
                        sans: ['"Plus Jakarta Sans"', 'sans-serif'],
                        mono: ['"JetBrains Mono"', '"Share Tech Mono"', 'monospace'],
                    },
                    boxShadow: {
                        'glow-broto': '0 0 24px -6px rgba(78, 238, 148, 0.45)',
                        'glow-agua': '0 0 24px -6px rgba(0, 245, 255, 0.35)',
                    },
                }
            }
        }
    </script>

    {# Estilos globais que o Tailwind puro não cobre bem: glass, scrollbar, sliders, bio-dimming #}
    <style>
        body {
            background-color: #0E1310;
            background-image: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(78, 238, 148, 0.08), transparent),
            radial-gradient(ellipse 60% 50% at 100% 100%, rgba(0, 245, 255, 0.05), transparent);
        }

        /* Vidro fosco das superfícies (cards, topbar, sidebar) */
        .glass-surface {
            background-color: rgba(20, 28, 24, 0.6);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid #22332A;
        }

        /* Scrollbar discreta, no tom do ecossistema */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #22332A; border-radius: 999px; }
        ::-webkit-scrollbar-thumb:hover { background: #2f4636; }

        /* Indicador de vitalidade do Core — pulso tipo batimento/fluxo de água */
        @keyframes vital-pulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.6); opacity: 0.35; }
        }
        .vital-dot::before {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: 999px;
            background: inherit;
            animation: vital-pulse 2.2s ease-in-out infinite;
        }

        /* Slider biomórfico (usado nas telas de módulo) */
        input[type="range"].bio-slider {
            -webkit-appearance: none;
            appearance: none;
            height: 4px;
            border-radius: 999px;
            background: #22332A;
        }
        input[type="range"].bio-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 16px; height: 16px;
            border-radius: 999px;
            background: #4EEE94;
            box-shadow: 0 0 10px rgba(78, 238, 148, 0.6);
            cursor: pointer;
            border: 2px solid #0E1310;
        }
        input[type="range"].bio-slider::-moz-range-thumb {
            width: 16px; height: 16px;
            border-radius: 999px;
            background: #4EEE94;
            box-shadow: 0 0 10px rgba(78, 238, 148, 0.6);
            cursor: pointer;
            border: 2px solid #0E1310;
        }

        /* -----------------------------------------------------------------
           MODO BIO-DIMMING
           Ativado via [data-bio-dim="true"] no <html> (toggle em JS no
           topbar). Reduz o brilho das cores de destaque em ~40% para uso
           noturno perto do ecossistema vivo, sem escurecer o texto legível.
        ----------------------------------------------------------------- */
        html[data-bio-dim="true"] .bio-dimmable {
            opacity: 0.6;
            filter: saturate(0.75) brightness(0.85);
            transition: opacity 0.4s ease, filter 0.4s ease;
        }
        .bio-dimmable { transition: opacity 0.4s ease, filter 0.4s ease; }
    </style>

    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-aether-bg text-slate-200 font-sans min-h-screen antialiased">

{# ======================= TOPBAR — "O Dossel" ======================= #}
<header class="fixed top-0 inset-x-0 z-40 h-16 glass-surface">
    <div class="h-full mx-auto max-w-[1600px] px-4 md:px-6 flex items-center justify-between gap-4">

        {# --- Esquerda: logo + vitalidade do Core --- #}
        <a href="{{ path('app_dashboard') }}" class="flex items-center gap-3 shrink-0">
            <span class="text-lg md:text-xl font-extrabold tracking-tight text-slate-50">Aether</span>
            <span class="relative flex items-center gap-1.5 pl-2 border-l border-aether-border">
                <span class="relative w-2 h-2 rounded-full bg-aether-broto vital-dot bio-dimmable"></span>
                <span class="hidden sm:inline text-[11px] font-mono uppercase tracking-wider text-aether-broto/80 bio-dimmable">Core online</span>
            </span>
        </a>

        {# --- Centro: módulos globais (oculto no mobile, vira bottom nav) --- #}
        <nav class="hidden md:flex items-center gap-1 text-sm font-medium">
            <a href="{{ path('app_dashboard') }}"
               class="px-3 py-1.5 rounded-full transition-colors {{ module_active|default('') == '' ? 'text-slate-50 bg-white/5' : 'text-slate-400 hover:text-slate-100 hover:bg-white/5' }}">
                Visão Geral
            </a>
            <a href="{{ path('app_modulo_poseidon') }}"
               class="px-3 py-1.5 rounded-full transition-colors {{ module_active|default('') == 'poseidon' ? 'text-aether-agua bg-aether-agua/10' : 'text-slate-400 hover:text-slate-100 hover:bg-white/5' }}">
                Poseidon
            </a>
            <a href="#"
               class="px-3 py-1.5 rounded-full transition-colors {{ module_active|default('') == 'horus' ? 'text-aether-ambar bg-aether-ambar/10' : 'text-slate-400 hover:text-slate-100 hover:bg-white/5' }}">
                Horus
            </a>
            <a href="#" class="px-3 py-1.5 rounded-full text-slate-400 hover:text-slate-100 hover:bg-white/5 transition-colors">
                Chronos
            </a>
        </nav>

        {# --- Direita: bio-dimming, notificações, perfil --- #}
        <div class="flex items-center gap-2 md:gap-3 shrink-0">
            {# Botão Bio-Dimming #}
            <button type="button" id="bio-dim-toggle"
                    class="flex items-center justify-center w-9 h-9 rounded-full border border-aether-border text-slate-400 hover:text-aether-ambar hover:border-aether-ambar/40 transition-colors"
                    title="Alternar Modo Bio-Dimming">
                <svg id="bio-dim-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-4.5 h-4.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1.5M12 19.5V21M4.219 4.219l1.061 1.061M18.72 18.72l1.06 1.06M3 12h1.5M19.5 12H21M4.219 19.781l1.061-1.061M18.72 5.28l1.06-1.06M16.5 12a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0Z" />
                </svg>
            </button>

            {# Notificações #}
            <button type="button" class="relative hidden sm:flex items-center justify-center w-9 h-9 rounded-full border border-aether-border text-slate-400 hover:text-slate-100 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-4.5 h-4.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.85 23.85 0 0 0 5.454-1.31A8.97 8.97 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.97 8.97 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.26 24.26 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
                </svg>
                <span class="absolute top-1.5 right-1.5 w-1.5 h-1.5 rounded-full bg-aether-critico"></span>
            </button>

            {# Perfil #}
            <button type="button" class="flex items-center gap-2 pl-1 pr-1 md:pr-3 py-1 rounded-full border border-aether-border hover:border-aether-broto/30 transition-colors">
                <span class="w-7 h-7 rounded-full bg-gradient-to-br from-aether-broto/40 to-aether-agua/30 border border-aether-border"></span>
                <span class="hidden md:inline text-xs font-medium text-slate-300">{{ app.user ? app.user.userIdentifier : 'Operador' }}</span>
            </button>
        </div>
    </div>
</header>

{# ============ Botão flutuante para abrir a sidebar no mobile (só aparece em páginas com sidebar) ============ #}
{% if block('layout_mode') == 'sidebar' %}
    <button type="button" id="sidebar-open-btn"
            class="lg:hidden fixed z-30 top-[4.5rem] left-4 flex items-center gap-2 px-3 py-1.5 rounded-full glass-surface text-xs font-medium text-slate-300">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
        </svg>
        Submenus
    </button>
{% endif %}

{# ======================= WRAPPER: Sidebar + Conteúdo ======================= #}
<div class="pt-16 pb-16 md:pb-0 min-h-screen flex">

    {# --------------------- SIDEBAR ESQUERDA — "As Raízes" --------------------- #}
    {% if block('layout_mode') == 'sidebar' %}
        {# Overlay mobile (fecha a sidebar ao clicar fora) #}
        <div id="sidebar-overlay" class="lg:hidden fixed inset-0 z-40 bg-black/60 backdrop-blur-sm hidden"></div>

        <aside id="sidebar"
               class="fixed z-50 lg:z-10 top-0 lg:top-16 left-0 h-full lg:h-[calc(100vh-4rem)] w-64 shrink-0
                      -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-out
                      glass-surface lg:bg-aether-surface/40 lg:border-r lg:border-t-0 lg:border-b-0 lg:border-l-0
                      p-4 overflow-y-auto">
            <div class="flex items-center justify-between mb-6 lg:hidden">
                <span class="text-xs font-mono uppercase tracking-widest text-slate-500">Submenus</span>
                <button type="button" id="sidebar-close-btn" class="text-slate-400 hover:text-slate-100">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            {% block sidebar %}{% endblock %}
        </aside>
    {% endif %}

    {# --------------------- ÁREA DE CONTEÚDO PRINCIPAL --------------------- #}
    <main class="flex-1 min-w-0 {% if block('layout_mode') == 'sidebar' %}lg:pl-64{% endif %} px-4 md:px-6 py-6">
        <div class="mx-auto max-w-[1400px]">
            {% block content %}{% endblock %}
        </div>
    </main>
</div>

{# ======================= BOTTOM NAV — mobile, estilo app ======================= #}
<nav class="md:hidden fixed bottom-0 inset-x-0 z-40 h-16 glass-surface flex items-stretch">
    <a href="{{ path('app_dashboard') }}" class="flex-1 flex flex-col items-center justify-center gap-1 {{ module_active|default('') == '' ? 'text-aether-broto' : 'text-slate-500' }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75" />
        </svg>
        <span class="text-[10px] font-medium">Visão Geral</span>
    </a>
    <a href="{{ path('app_modulo_poseidon') }}" class="flex-1 flex flex-col items-center justify-center gap-1 {{ module_active|default('') == 'poseidon' ? 'text-aether-agua' : 'text-slate-500' }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21c-4.97 0-9-3.5-9-8 0-3.5 3-6 4.5-9.5C9 6 10.5 3 12 3s3 3 4.5 4.5C18 11 21 9.5 21 13c0 4.5-4.03 8-9 8Z" />
        </svg>
        <span class="text-[10px] font-medium">Poseidon</span>
    </a>
    <a href="#" class="flex-1 flex flex-col items-center justify-center gap-1 {{ module_active|default('') == 'horus' ? 'text-aether-ambar' : 'text-slate-500' }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
        </svg>
        <span class="text-[10px] font-medium">Horus</span>
    </a>
    <a href="#" class="flex-1 flex flex-col items-center justify-center gap-1 text-slate-500">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.828c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.829c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.828c.292-.24.437-.613.43-.992a6.932 6.932 0 0 1 0-.255c.007-.378-.138-.75-.43-.991l-1.004-.829a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
        </svg>
        <span class="text-[10px] font-medium">Config</span>
    </a>
</nav>

<script>
    // --- Bio-Dimming: alterna atributo data-bio-dim no <html> e persiste na sessão ---
    (function () {
        const html = document.documentElement;
        const btn = document.getElementById('bio-dim-toggle');
        const saved = sessionStorage.getItem('aether-bio-dim');
        if (saved === 'true') html.setAttribute('data-bio-dim', 'true');

        btn?.addEventListener('click', function () {
            const isOn = html.getAttribute('data-bio-dim') === 'true';
            html.setAttribute('data-bio-dim', String(!isOn));
            sessionStorage.setItem('aether-bio-dim', String(!isOn));
            btn.classList.toggle('text-aether-ambar', !isOn);
        });
    })();

    // --- Sidebar mobile: abrir/fechar drawer ---
    (function () {
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebar-overlay');
        const openBtn = document.getElementById('sidebar-open-btn');
        const closeBtn = document.getElementById('sidebar-close-btn');
        if (!sidebar) return;

        function openSidebar() {
            sidebar.classList.remove('-translate-x-full');
            overlay?.classList.remove('hidden');
        }
        function closeSidebar() {
            sidebar.classList.add('-translate-x-full');
            overlay?.classList.add('hidden');
        }
        openBtn?.addEventListener('click', openSidebar);
        closeBtn?.addEventListener('click', closeSidebar);
        overlay?.addEventListener('click', closeSidebar);
    })();
</script>

{% block javascripts %}{% endblock %}
</body>
</html>
